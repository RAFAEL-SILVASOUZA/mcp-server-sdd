{
  "name": "@rafaelsouza-ai/mcp-server-sdd",
  "version": "1.2.1",
  "description": "MCP Server for Spec-Driven Development - Create and manage SDD test specifications with tasks, logs, and acceptance criteria",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "mcp-server-sdd": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "copy:wasm": "node scripts/copy-wasm.mjs",
    "build": "tsc && npm run copy:wasm && node scripts/add-shebang.mjs",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build",
    "release:patch": "npm version patch && npm publish --access public",
    "release:minor": "npm version minor && npm publish --access public",
    "release:major": "npm version major && npm publish --access public"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "sdd",
    "spec-driven-development",
    "ai-agent",
    "claude",
    "claude-code",
    "cursor",
    "windsurf",
    "task-management",
    "kanban",
    "dashboard",
    "workflow",
    "agent-workflow",
    "spec-first",
    "acceptance-criteria",
    "sqlite"
  ],
  "homepage": "https://www.npmjs.com/package/@rafaelsouza-ai/mcp-server-sdd",
  "author": "Rafael Silva Souza",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/express": "^5.0.6",
    "@types/ws": "^8.18.1",
    "express": "^5.2.1",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.1",
    "ws": "^8.20.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/sql.js": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "mcpServer": {
    "main": "dist/index.js"
  }
}
